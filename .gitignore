# Dependencies
node_modules/
.pnp/
.pnp.js

# Build outputs
.next/
out/
build/
dist/
target/
dbt_packages/
logs/

# Vercel
.vercel/

# Env & Secrets
.env
.env.local
.env.*
# Templates (no real values) MUST stay tracked so a fresh clone has the
# documented variables list. Re-include after the broad .env.* pattern.
!.env.example
!**/.env.example
credentials.json
*-credentials.json
service-account*.json
*.pem
*.key

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
*.swp
*.swo

# Python
.venv/
__pycache__/
*.pyc

# Cache / large files
.cache/

# Temp files
*.json.bak
*.log

# Large local assets
mockups/
/archive/
instagram-stories/
# Note: docs/archive/ is intentionally NOT ignored (refactor audit trail).
# The /archive/ pattern is anchored to repo root to avoid matching it.

# Pipeline outputs
pipeline/output/

# Backup directories
.git.broken/

# Pipeline cache — large binaries / regenerable artifacts (3+GB)
# Includes : delibs PDF/HTML, DECP raw dumps, DGFiP, OFGL rapport,
# enrichment WIP, PDF extracts, sessions
pipeline/cache/

# Local stdout dumps (foreground/background dev runs)
nohup.out

# Chat conversations (file-based store)
data/conversations/
website/data/conversations/

# Python bytecode (pipeline scripts)
__pycache__/
*.pyc
