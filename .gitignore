# Pipeline outputs
pipeline/output/

# Backup directories
.git.broken/

# Pipeline cache — large binaries / regenerable artifacts (3+GB)
# Includes : delibs PDF/HTML, DECP raw dumps, DGFiP, OFGL rapport,
# enrichment WIP, PDF extracts, sessions
pipeline/cache/

# Local stdout dumps (foreground/background dev runs)
nohup.out

# Chat conversations (file-based store)
data/conversations/
website/data/conversations/

# Python bytecode (pipeline scripts)
__pycache__/
*.pyc

# National budget-by-nature exports — 828MB/104k files at full scale.
# Delivery is being decided (sharding/API); do NOT commit the bulk. The 2 test
# communes (albi, cerizay) are already tracked from Block 1 and stay committed.
# Site data (JSON exports, ~123MB) lives in the PRIVATE gs://qipu-site-data
# bucket, hydrated at build (npm run prebuild). Commune budget JSON (bucket
# gs://qipu-communes-budget) is fetched at runtime. Repo carries none of it.
website/public/data/

# Generated enrichment caches (LLM/geocode/fuzzy-match/lieux) — the moat. Live in
# gs://qipu-site-data/seeds-private, hydrated by pipeline/scripts/sync/hydrate_private_seeds.sh
# before `dbt seed`. The enrich SCRIPTS + prompts stay in the repo (method open).
pipeline/seeds/seed_cache_geo_ap.csv
pipeline/seeds/seed_cache_siret_by_name.csv
pipeline/seeds/seed_cache_thematique_beneficiaires.csv
pipeline/seeds/seed_lieux_connus.csv
pipeline/seeds/seed_match_projet_marches.csv

# National marchés (DECP) exports — private bucket gs://qipu-communes-budget/communes-marches
website/public/data/communes-marches/
