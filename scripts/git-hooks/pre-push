#!/usr/bin/env bash
# Committed pre-push hook for the Qipu pipeline.
#
# Install once (per clone):   git config core.hooksPath scripts/git-hooks
#
# 1. Always: compile-check the export + sync scripts (fast, creds-free).
# 2. If BigQuery creds are present: run the tolerant Paris export-parity gate,
#    so a refactor can't silently change a published number. Skipped (with a
#    notice) when no creds, or when SKIP_PARITY=1.
set -uo pipefail

REPO="$(git rev-parse --show-toplevel)"
fail=0

echo "pre-push: py_compile export + sync scripts…"
if ! python3 -m py_compile "$REPO"/pipeline/scripts/export/*.py "$REPO"/pipeline/scripts/sync/*.py; then
  echo "  ✗ compile failed" >&2
  fail=1
fi

if [ "${SKIP_PARITY:-0}" = "1" ]; then
  echo "pre-push: export parity skipped (SKIP_PARITY=1)."
elif [ -n "${GOOGLE_APPLICATION_CREDENTIALS:-}" ] || [ -f "$HOME/.config/gcloud/application_default_credentials.json" ]; then
  echo "pre-push: tolerant Paris export parity…"
  if ! bash "$REPO/pipeline/scripts/export/check_export_parity.sh"; then
    echo "  ✗ export parity failed — a published number changed. Review before pushing." >&2
    fail=1
  fi
else
  echo "pre-push: export parity skipped (no BigQuery creds). Run pipeline/scripts/export/check_export_parity.sh manually, or in CI."
fi

exit "$fail"
