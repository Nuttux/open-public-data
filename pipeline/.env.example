# =============================================================================
# pipeline/.env.example — copy to pipeline/.env and fill in real values
# =============================================================================
# This file is committed. Real .env files are in .gitignore.
# Most pipeline scripts read env via `os.environ.get(...)` and degrade
# gracefully if a key is missing (skips the corresponding enrichment step).
#
# Source the file before running pipeline scripts:
#   set -a && source pipeline/.env && set +a
# Or use a tool like `direnv` / `dotenv-cli`.

# ---------------------------------------------------------------------------
# BigQuery — required for any dbt run or export script.
# ---------------------------------------------------------------------------
# Path to a Google service account JSON file with BigQuery Job User +
# Data Editor roles on the project. Must be absolute, must NOT be in the repo.
# Generate via GCP Console → IAM & Admin → Service Accounts → Keys.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# ---------------------------------------------------------------------------
# Anthropic API — used by enrichment LLM scripts (vulgarize_*, enrich_*_llm)
# ---------------------------------------------------------------------------
# Tier 1 enrichment (large amounts, ≥80k€ marchés) is opt-in via --tier1
# in run_all.sh — uses billed quota. Without the key, scripts skip gracefully.
ANTHROPIC_API_KEY=sk-ant-api03-...
# CLAUDE_MODEL=claude-sonnet-4-5-20250929
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
# CLAUDE_CALL_DELAY=0.2   # seconds between calls if rate-limited

# ---------------------------------------------------------------------------
# Google Gemini API — alternative LLM for grounded enrichment (cheaper)
# ---------------------------------------------------------------------------
# Used by enrich_beneficiaire_grounded_llm.py for SIRET resolution with
# Google Search grounding. Without the key, that script is skipped.
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# Some scripts use GOOGLE_API_KEY (alternative env name for the same key).
# Leave one of the two set; scripts read both.
GOOGLE_API_KEY=

# ---------------------------------------------------------------------------
# Photo banks (project illustration enrichment)
# ---------------------------------------------------------------------------
# Used by build_generic_photo_bank.py and match_projet_photos.py.
# All three are optional — without keys, scripts fall back to pictograms.
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
# Used by some Anthropic-routed chat tools in pipeline scripts.
# CHAT_MODEL=claude-sonnet-4-5-20250929

# Dotabs.io API token if used (rare). Leave empty if unused.
# DOT_DB_TOKEN=
