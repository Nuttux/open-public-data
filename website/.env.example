# =============================================================================
# website/.env.example — copy to .env.local and fill in real values
# =============================================================================
# This file is committed to git. Real .env.local files are in .gitignore.
# All NEXT_PUBLIC_* vars are exposed to the browser bundle — never put
# secrets there.
#
# After editing .env.local, restart `npm run dev` for changes to take effect.

# ---------------------------------------------------------------------------
# Anthropic API — used by the chat assistant route (/api/chat).
# ---------------------------------------------------------------------------
# Required to run the chat feature locally. Without it, /chat returns 500.
# Get a key from https://console.anthropic.com.
# Server-side only — never expose with NEXT_PUBLIC_ prefix.
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: pin a specific model. Defaults to the project's chosen Claude
# model if unset. Useful for testing model upgrades without code changes.
# CHAT_MODEL=claude-sonnet-4-5-20250929

# ---------------------------------------------------------------------------
# PostHog analytics (EU region — CNIL-exemption mode by default)
# ---------------------------------------------------------------------------
# Obtain a project API key from https://eu.posthog.com after signup.
# The _HOST stays on the EU region to keep data in the EU (RGPD).
# Both vars are exposed to the browser (NEXT_PUBLIC_*) — that's expected
# for a client-side analytics SDK.
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# For self-hosted later:
# NEXT_PUBLIC_POSTHOG_HOST=https://posthog.your-domain.fr

# ---------------------------------------------------------------------------
# Sentry — error tracking client + server (cat. 3 observabilité)
# ---------------------------------------------------------------------------
# Get DSNs from https://sentry.io after creating a project.
# Without these, Sentry SDK no-ops silently (no crash, no events sent).
# Active uniquement quand VERCEL_ENV=production (cf sentry.*.config.ts).
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX

# Required only for source map upload during build (CI).
# Generate via Sentry → Settings → Auth Tokens → "scoped: project:releases".
# Server-side only.
# SENTRY_AUTH_TOKEN=

# Org + project slugs (used by withSentryConfig if you wrap next.config.ts later).
# SENTRY_ORG=open-data-france
# SENTRY_PROJECT=website

# ---------------------------------------------------------------------------
# Plausible Analytics — alternative privacy-friendly à PostHog (cat. 3)
# ---------------------------------------------------------------------------
# Active uniquement si NEXT_PUBLIC_PLAUSIBLE_DOMAIN est set.
# Pas de bandeau cookies requis (Plausible CNIL-exempt by construction).
# Coexiste avec PostHog — choix actuel : garder les deux temporairement.
# Sign up à https://plausible.io ou self-host (https://plausible.io/docs/self-hosting).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=franceopendata.org

# ---------------------------------------------------------------------------
# Better Stack — uptime monitoring + status page publique (cat. 3)
# ---------------------------------------------------------------------------
# URL de la status page publique configurée chez Better Stack.
# Affichée dans le footer du site (lien "Status" si défini).
# Setup : https://betterstack.com → Status pages → New.
# CNAME `status.franceopendata.org` à ajouter chez NameCheap.
NEXT_PUBLIC_STATUS_PAGE_URL=https://status.franceopendata.org
